---
---

<html lang="en">
  <body class="bg-black text-white p-6 flex flex-col items-center justify-center min-h-screen">
    <h1 class="text-3xl font-bold mb-4">🕵️ Join Spy Among Prompts</h1>
    <form
      id="spy-join-form"
      class="flex flex-col gap-4 w-full max-w-md"
    >
      <input
        type="text"
        name="name"
        placeholder="Your name"
        class="p-3 rounded bg-neutral-800 border border-neutral-600 text-white"
        required
      />
      <input
        type="text"
        name="sessionId"
        placeholder="Session ID"
        class="p-3 rounded bg-neutral-800 border border-neutral-600 text-white"
        required
      />
      <button
        type="submit"
        class="bg-red-600 hover:bg-red-700 py-2 px-4 rounded"
      >
        🚀 Start Game
      </button>
    </form>
  </body>
</html>

<script>
  const form = document.getElementById("spy-join-form") as HTMLFormElement;
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const formData = new FormData(form);
    const name = (formData.get("name") as string)?.trim();
    const sessionId = (formData.get("sessionId") as string)?.trim();

    if (name && sessionId) {
      localStorage.setItem("spyName", name);
      window.location.href = `/spy/join?sessionId=${sessionId}`;
    }
  });
</script>
