---
import BasicLayout from "../../layouts/BasicLayout.astro";
import ClinicalTrialSummarizer from "../../components/ClinicalTrialSummarizer.tsx";
---

<BasicLayout title="Clinical Trial Summarizer — Harsh Maan" description="AI-powered clinical trial summarizer using ClinicalTrials.gov API and Gemini.">
  <main class="p-6 max-w-5xl mx-auto text-white min-h-screen py-12">
    <a href="/projects" class="text-sm text-gray-400 hover:text-white mb-6 inline-block">← Back to Projects</a>

    <div class="mb-8">
      <h1 class="text-3xl font-bold mb-2">🔬 Clinical Trial Summarizer</h1>
      <p class="text-gray-400 max-w-2xl">
        Paste a ClinicalTrials.gov NCT ID and get an AI-generated plain English summary — including key facts, eligibility, and why the trial matters.
      </p>
    </div>

    <ClinicalTrialSummarizer client:load />
  </main>
</BasicLayout>
